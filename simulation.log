cp -r $CMSSW_RELEASE_BASE/src/GeneratorInterface/Pythia8Interface/* GeneratorInterface/Pythia8Interface/

# 3. Replace the official gun with your custom modified version
cp /eos/home-a/asmishra/Py8PtGun.cc.saved GeneratorInterface/Pythia8Interface/plugins/Py8PtGun.cc

# 4. Clean out all broken cache and build ONLY this package
scram b clean
scram b -j32 src/GeneratorInterface/Pythia8Interface

